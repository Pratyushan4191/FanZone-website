{
  "name": "fanzone-website",
  "version": "1.0.0",
  "description": "FanZone Interactive Web App",
  "main": "api/index.js",
  "type": "module",
  "scripts": {
    "server": "node api/index.js",
    "client": "npm run dev --prefix frontend",
